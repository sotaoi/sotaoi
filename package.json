{
  "name": "qwertyboilerplate",
  "private": true,
  "version": "0.9.1",
  "description": "",
  "engines": {
    "node": "14.x"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node ./start.js",
    "start:api": "cross-env NODE_ENV=development PORT=3000 NODE_TLS_REJECT_UNAUTHORIZED=0 nodemon --config ./sotaoi/api/cfg-nodemon-api.json",
    "start:cweb": "cross-env NODE_ENV=development ts-node ./sotaoi/omni/build/cweb.server.ts --info ./app/omni/info.json",
    "start:crns": "react-native start > ./rn.log 2>&1 & tail -f ./rn.log",
    "start:candroid": "node ./var/build/run-android.js",
    "start:cios": "node ./var/build/run-ios.js",
    "start:proxy": "cross-env NODE_ENV=development PORT=443 nodemon --config ./sotaoi/api/cfg-nodemon-proxy.json",
    "build:cweb": "ts-node ./sotaoi/omni/build/cweb.build.ts",
    "build:prod": "ts-node ./sotaoi/omni/build/build.ts",
    "deploy:heroku": "ts-node ./var/deploy.heroku.ts",
    "start:api:prod": "cross-env NODE_ENV=production PORT=3000 NODE_TLS_REJECT_UNAUTHORIZED=0 node ./app/api/api.entry.js",
    "start:cweb:prod": "cross-env NODE_ENV=production PORT=8080 node ./app/client/cweb.entry.prod.js",
    "start:proxy:prod": "cross-env NODE_ENV=production node ./app/api/proxy.entry.js",
    "dev:create-database": "ts-node ./sotaoi/omni/scripts/dev/create-database.ts",
    "dev:setup-env": "npm install && ts-node ./sotaoi/omni/scripts/dev/setup-env.ts --info ./app/omni/info.json",
    "dev:devreset": "npx rimraf ./node_modules && npm install",
    "db:migrate": "knex migrate:latest",
    "db:migrate:make": "knex migrate:make",
    "db:migrate:rollback": "knex migrate:rollback",
    "db:migrate:down": "knex migrate:down",
    "db:migrate:undo": "knex migrate:down",
    "db:seed": "knex seed:run",
    "format": "prettier './**/*.ts' --write && prettier './**/*.tsx' --write",
    "test": "",
    "postinstall": "node ./var/pmhook.js",
    "rr": "adb reverse tcp:8081 tcp:8081"
  },
  "dependencies": {
    "7zip-bin": "^5.0.3",
