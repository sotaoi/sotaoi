{
  "name": "qwertyboilerplate",
  "private": true,
  "version": "0.9.1",
  "description": "",
  "engines": {
    "node": "14.x"
  },
  "flags": {
    "isBuild": false
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node ./start.js",
    "start:api:only": "cross-env NODE_ENV=development PORT=3000 NODE_TLS_REJECT_UNAUTHORIZED=0 nodemon --config ./sotaoi/api/cfg-nodemon-api.json",
    "start:api": "concurrently --kill-others \"npm run start:mongo\" \"npm run start:api:only\"",
    "start:php": "cross-env NODE_ENV=development node ./php/var/phpprx.js",
    "start:cweb": "cross-env NODE_ENV=development ts-node ./app/client/cweb.entry.ts --servebuild no --info ./app/omni/app-info.json",
    "start:crns": "react-native start > ./rn.log 2>&1 & tail -f ./rn.log",
    "start:candroid": "node ./var/build/run-android.js",
    "start:cios": "node ./var/build/run-ios.js",
    "start:proxy": "cross-env NODE_ENV=development PORT=443 nodemon --config ./sotaoi/api/cfg-nodemon-proxy.json",
    "build:prod": "cross-env NODE_ENV=production ts-node ./sotaoi/omni/build/build.ts",
    "clean:mobile": "node ./var/build/clean-mobile.js",
    "start:api:only:prod": "cross-env NODE_ENV=production PORT=3000 NODE_TLS_REJECT_UNAUTHORIZED=0 node ./app/api/api.entry.js",
    "start:api:prod": "concurrently --kill-others \"npm run start:mongo\" \"npm run start:api:only:prod\"",
    "start:php:prod": "cross-env NODE_ENV=production node ./php/var/phpprx.js",
    "start:cweb:prod": "cross-env NODE_ENV=production PORT=8080 node ./app/client/cweb.entry.js --servebuild yes",
    "start:proxy:prod": "cross-env NODE_ENV=production node ./app/api/proxy.entry.js",
    "start:testserver": "cross-env ts-node ./app/api/proxy.entry.ts --testserver",
    "start:mongo": "cross-env mongod --dbpath ./var/mongo --logpath ./var/mongo/log",
    "db:seed:prod": "node ./scripts/db-seed.js",
    "db:seed": "ts-node ./scripts/db-seed.ts",
    "db:migrate:todel": "knex migrate:latest",
    "db:migrate:make:todel": "knex migrate:make",
    "db:migrate:rollback:todel": "knex migrate:rollback",
    "db:migrate:down:todel": "knex migrate:down",
    "db:migrate:undo:todel": "knex migrate:down",
    "dev:install": "ts-node ./scripts/dev-install.ts",
    "format": "prettier './**/*.ts' --write && prettier './**/*.tsx' --write",
    "postinstall": "node ./var/pmhook.js",
    "rr": "adb reverse tcp:8081 tcp:8081",
    "ssl:greenlock": "cross-env NODE_ENV=development ts-node ./scripts/ssl-greenlock.ts",
    "ssl:greenlock:prod": "cross-env NODE_ENV=production node ./scripts/ssl-greenlock.js",
    "test": "",
    "todo here:stage:greenlock": "npx cross-env NODE_ENV=staging node ./scripts/greenlock.js",
    "todo here:prod:greenlock": "npx cross-env NODE_ENV=production node ./scripts/greenlock.js"
  },
  "dependencies": {
    "7zip-bin": "^5.0.3",
    "@app/api": "file:app/api",
    "@app/client": "file:app/client",
    "@app/omni": "file:app/omni",
    "@babel/core": "^7.8.4",
    "@babel/runtime": "^7.8.4",
    "@fullhuman/postcss-purgecss": "^3.0.0",
    "@greenlock/manager": "^3.1.0",
    "@hapi/hapi": "19.1.1",
    "@hapi/inert": "^6.0.3",
    "@hapi/vision": "^6.0.1",
    "@material-ui/core": "^4.11.3",
    "@prettier/plugin-php": "^0.16.1",
    "@react-native-community/async-storage": "^1.12.1",
    "@react-native-community/cli": "^4.13.0",
    "@react-native-picker/picker": "^1.9.4",
    "@sotaoi/api": "file:sotaoi/api",
    "@sotaoi/client": "file:sotaoi/client",
    "@sotaoi/modules": "file:sotaoi/modules",
    "@sotaoi/omni": "file:sotaoi/omni",
    "@types/hapi-cors": "file:sotaoi/api/types/hapi-cors",
    "@types/hapi__hapi": "^19.0.3",
    "@types/hapi__inert": "^5.2.0",
    "@types/hapi__vision": "^5.5.2",
    "@types/invariant": "^2.2.34",
    "@types/jsonic": "^0.3.0",
    "@types/lodash": "^4.14.165",
    "@types/node": "^14.0.14",
    "@types/oauth2-server": "^3.0.12",
    "@types/react": "^16.9.41",
    "@types/react-dom": "^16.9.8",
    "@types/react-native": "^0.63.0",
    "@types/react-redux": "^7.1.9",
    "@types/sha1": "^1.1.2",
    "@types/terser-webpack-plugin": "^4.1.0",
    "@types/text-encoding": "0.0.35",
    "@types/uuid": "^8.0.0",
    "@types/webpack-dev-server": "^3.11.0",
    "@types/webpack-node-externals": "^2.5.0",
    "@typescript-eslint/eslint-plugin": "^3.5.0",
    "@typescript-eslint/parser": "^3.5.0",
    "autoprefixer": "^9.8.6",
    "babel-plugin-inline-dotenv": "^1.6.0",
    "babel-plugin-module-resolver": "^4.0.0",
    "chalk": "^4.1.0",
    "concurrently": "^6.0.2",
    "cross-env": "^7.0.2",
    "css-loader": "^5.0.1",
    "dotenv": "^8.2.0",
    "eslint": "^7.4.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.4",
    "express": "^4.17.1",
    "flatted": "^3.0.4",
    "form-data": "^3.0.0",
    "greenlock": "^4.0.4",
    "greenlock-store-fs": "^3.2.2",
    "hapi-cors": "^1.0.3",
    "html-webpack-plugin": "^4.3.0",
    "http-proxy-middleware": "^1.0.5",
    "i18next": "^20.2.1",
    "invariant": "^2.2.4",
    "joi": "^17.3.0",
    "jsonic": "^1.0.1",
    "jwt-simple": "^0.5.6",
    "lodash": "^4.17.20",
    "metro-react-native-babel-preset": "^0.59.0",
    "mongoose": "^5.12.5",
    "node-7z": "^2.1.1",
    "nodemon": "^2.0.4",
    "oauth2-server": "^3.1.1",
    "onchange": "^7.0.2",
    "postcss": "^7.0.35",
    "postcss-cli": "^8.3.0",
    "prettier": "^2.0.5",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-i18next": "^11.8.13",
    "react-native": "0.63.0",
    "react-native-gesture-handler": "^1.9.0",
    "react-native-material-kit": "^0.6.0-beta.1",
    "react-native-paper": "^4.7.1",
    "react-native-reanimated": "^1.13.2",
    "react-native-router-flux": "^4.2.0",
    "react-native-screens": "^2.15.0",
    "react-native-vector-icons": "^8.0.0",
    "react-redux": "^7.2.0",
    "redux": "^4.0.5",
    "rimraf": "^3.0.2",
    "sha1": "^1.1.1",
    "socket.io": "^3.1.1",
    "style-loader": "^2.0.0",
    "tail": "^2.2.0",
    "tailwind-rn": "^2.0.1",
    "tailwindcss": "npm:@tailwindcss/postcss7-compat@^2.0.1",
    "terser-webpack-plugin": "^4.2.0",
    "text-encoding": "^0.7.0",
    "ts-loader": "^7.0.5",
    "ts-node": "^8.10.2",
    "tsconfig-paths-webpack-plugin": "^3.3.0",
    "typescript": "^3.9.7",
    "uuid": "^8.2.0",
    "webpack": "^4.43.0",
    "webpack-dev-server": "^3.11.0",
    "webpack-node-externals": "^2.5.2",
    "yargs": "^16.1.1"
  },
  "envVarWhitelist": [
    "NODE_ENV",
    "APP_NAME",
    "BUNDLE_ID",
    "PACKAGE_NAME",
    "LOCAL_DOMAIN",
    "LOCAL_DOMAIN_ALIAS",
    "DEV_DOMAIN",
    "DEV_DOMAIN_ALIAS",
    "STAGE_DOMAIN",
    "STAGE_DOMAIN_ALIAS",
    "PROD_DOMAIN",
    "PROD_DOMAIN_ALIAS",
    "MOBILE_BUNDLE_LOCATION",
    "GREENLOCK_EXECUTION",
    "SSL_MAINTAINER"
  ]
}
